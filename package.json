{
  "name": "@incsub/emdash-contact-form",
  "version": "0.2.1",
  "description": "Contact form plugin for EmDash CMS — collect submissions, manage them in the admin UI, and embed forms via a single-line shortcode.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sandbox": {
      "types": "./dist/sandbox-entry.d.ts",
      "import": "./dist/sandbox-entry.js"
    },
    "./astro": {
      "types": "./dist/astro/index.d.ts",
      "import": "./dist/astro/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "emdash": ">=0.9.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "emdash",
    "emdash-plugin",
    "cms",
    "contact-form",
    "form",
    "submissions",
    "astro"
  ],
  "author": "Incsub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neelg12/emdash-contact-form.git"
  },
  "bugs": {
    "url": "https://github.com/neelg12/emdash-contact-form/issues"
  },
  "homepage": "https://github.com/neelg12/emdash-contact-form#readme",
  "engines": {
    "node": ">=18"
  }
}
